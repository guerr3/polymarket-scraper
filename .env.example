# PostgreSQL (required for --store / daemon mode)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polymarket

# Supabase (optional alternative)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Proxy (optional, for anti-bot resilience)
# PROXY_URL=http://proxy:8080

# CLOB auth (optional for endpoints like /trades when auth is required)
# CLOB_API_KEY=your-clob-api-key
# CLOB_API_KEY_HEADER=X-API-Key
# CLOB_AUTH_SCHEME=Bearer
